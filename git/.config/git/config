	name = James van de Ven
	email = james.vandeven@woodside.com
[core]
	editor = nvim
	pager = less
	excludesfile = $HOME/.config/git/gitignore_global
	autocrlf = input
[alias]
	br = branch
	bl = branch -l
	ci = commit
	co = checkout
	nb = checkout -b
	st = status
[init]
	defaultBranch = main
[pull]
	rebase = false
